SERVE_FRONTEND=false
FRONTEND_ORIGIN=http://localhost:5173,https://tu-frontend.up.railway.app

# ─── Evolution API (WhatsApp QR) ─────────────────────────────────
EVOLUTION_API_URL=https://tu-evolution-api.up.railway.app
EVOLUTION_API_KEY=tu_api_key
