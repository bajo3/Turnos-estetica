# ─── Negocio ─────────────────────────────────────────────────────
OWNER_WHATSAPP_NUMBER=5492494XXXXXX
OWNER_DISPLAY_NAME=Emme
SALON_NAME=Emme Estética

# ─── Google Calendar OAuth ────────────────────────────────────────
# Obtené en console.cloud.google.com → API Calendar → OAuth 2.0
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_REDIRECT_URI=https://tu-backend.up.railway.app/auth/google/callback
GOOGLE_CALENDAR_ID=primary

# ─── Frontend ─────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
